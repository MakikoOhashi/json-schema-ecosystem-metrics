{
  "name": "json-schema-ecosystem-metrics",
  "version": "1.0.0",
  "description": "Proof-of-concept metrics collection for the JSON Schema ecosystem",
  "main": "src/fetch-ajv-downloads.js",
  "scripts": {
    "fetch": "node src/fetch-ajv-downloads.js",
    "fetch:downloads": "node src/fetch-ajv-downloads.js",
    "fetch:proxy-rate": "node src/fetch-schema-usage-proxy-rate.js",
    "fetch:proxy-rate:small": "CANDIDATES_PER_LANGUAGE=40 BROAD_SAMPLE_SIZE=12 FOCUSED_SAMPLE_SIZE=8 node src/fetch-schema-usage-proxy-rate.js",
    "fetch:proxy-rate:tiny": "CANDIDATES_PER_LANGUAGE=20 BROAD_SAMPLE_SIZE=6 FOCUSED_SAMPLE_SIZE=4 node src/fetch-schema-usage-proxy-rate.js",
    "build:dashboard": "node src/build-observability-dashboard.js",
    "fetch:all": "npm run fetch:downloads && npm run fetch:proxy-rate && npm run build:dashboard",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MakikoOhashi/json-schema-ecosystem-metrics.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MakikoOhashi/json-schema-ecosystem-metrics/issues"
  },
  "homepage": "https://github.com/MakikoOhashi/json-schema-ecosystem-metrics#readme"
}
